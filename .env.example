NODE_ENV=production
PORT=3000

# REQUIRED in production — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret-key

# PostgreSQL database connection
DATABASE_URL=postgresql://user:password@localhost:5432/royalcar

# Base URL for links in emails (password reset, etc.)
BASE_URL=https://royalcar.rent

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://royalcar.rent,https://www.royalcar.rent

# Email (SMTP) settings — required for password reset, booking notifications, contact form
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

# Contact form recipient email
CONTACT_EMAIL=your-email@gmail.com

# Twilio SMS — required for phone verification and booking OTP
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-service-sid

# Google OAuth (optional — for Google login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# PayPal — set to 'live' for production
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
